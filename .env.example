# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local:   postgresql://postgres:password@localhost:5432/rezichem
# Vercel:  Use Vercel Postgres or Neon — paste the connection string from the dashboard
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/rezichem

# ─── App ─────────────────────────────────────────────────────────────────────
# Set to your production domain on Vercel (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://rezichem.vercel.app

# ─── Auth (optional — add when protecting /admin) ────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-random-secret
NEXTAUTH_URL=https://rezichem.vercel.app

# ─── AWS S3 Uploads (Admin Product Images) ─────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=your-s3-bucket-name
# Public base URL used to save final image URL in DB.
# Example:
# AWS_S3_PUBLIC_BASE_URL=https://your-bucket.s3.ap-south-1.amazonaws.com
AWS_S3_PUBLIC_BASE_URL=https://your-bucket.s3.amazonaws.com
